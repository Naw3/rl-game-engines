# =============================================================================
# pipeline.conf.ps1 — Configuration centrale de la pipeline Connect4.
#
# Ce fichier est chargé automatiquement par run_pipeline.ps1 au démarrage.
# Modifie les valeurs ici pour changer le comportement de toute la pipeline,
# sans jamais toucher au code des scripts.
#
# Usage : édite ce fichier, puis lance .\run_pipeline.ps1 normalement.
# =============================================================================

# -----------------------------------------------------------------------------
# DEVICE (inférence Rust pendant le self-play)
# -----------------------------------------------------------------------------
# Valeurs : "gpu"  → ort + CUDA (utilise le dispatcher centralisé, ~20s/cycle)
#           "cpu"  → tract-onnx pur Rust (pas besoin de CUDA, ~96s/cycle)
#           "auto" → GPU si disponible, sinon CPU
$env:RUST_DEVICE = "gpu"

# Python est TOUJOURS sur CUDA (design contract immuable).
# Ne change pas cette ligne.
$env:PYTHON_DEVICE = "cuda"

# -----------------------------------------------------------------------------
# SELF-PLAY (paramètres Rust MCTS)
# -----------------------------------------------------------------------------

# Nombre de parties jouées par cycle.
# Plus = plus de données = meilleur apprentissage, mais plus lent.
$env:GAMES = "64"

# Nombre de simulations MCTS par coup.
# Plus = meilleure qualité de coup, mais plus lent.
$env:SIMS = "800"

# Taille du batch d'inférence NN (boards traités ensemble par le dispatcher).
# Sur GPU : 32-64 est optimal. Sur CPU : idem (le dispatcher groupe de toute façon).
$env:BATCH_SIZE = "32"

# -----------------------------------------------------------------------------
# ENTRAÎNEMENT (paramètres Python)
# -----------------------------------------------------------------------------

# Nombre de passes d'entraînement sur les données de replay.
$env:EPOCHS = "5"

# Taille des mini-batches pendant l'entraînement.
$env:BATCH = "256"

# Nombre de fichiers de replay conservés (rolling window de données passées).
# Plus = l'agent apprend sur plus d'historique, mais peut ralentir la convergence.
$env:REPLAY_KEEP = "10"

# Augmentation par symétrie horizontale (flip) : "1" = activé, "0" = désactivé.
$env:SYMMETRY = "1"

# -----------------------------------------------------------------------------
# BOUCLE PIPELINE
# -----------------------------------------------------------------------------

# Nombre de cycles à exécuter. 0 = infini (Ctrl-C pour arrêter).
$env:MAX_CYCLES = "0"

# Pause (en secondes) entre deux cycles.
$env:SLEEP = "2"

# -----------------------------------------------------------------------------
# CHEMINS (laisse par défaut sauf si tu déplaces les fichiers)
# -----------------------------------------------------------------------------
# $env:MODEL      = "connect4_model.pt"
# $env:MODEL_ONNX = "connect4_model.onnx"
# $env:DATA       = "selfplay.bin"
